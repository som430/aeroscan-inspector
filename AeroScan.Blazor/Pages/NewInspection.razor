@page "/new-inspection"
@using System.Net.Http
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.WebAssembly.Http
@using Microsoft.JSInterop
@using AeroScan.Blazor
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>New Inspection — AeroScan</PageTitle>

<div class="page-header">
    <h1>New Inspection</h1>
    <p class="subtitle">점군 파일(.csv 또는 .ply)을 업로드해서 평탄도 검사를 실행합니다.</p>
</div>

<div class="form-card">

    @if (_step == Step.Form)
    {
        <div class="form-grid">
            <div class="form-group">
                <label>Part Name *</label>
                <input class="input" @bind="_partName" placeholder="e.g. Wing Panel A3" />
            </div>
            <div class="form-group">
                <label>Part Number *</label>
                <input class="input" @bind="_partNumber" placeholder="e.g. BP-7X-0042" />
            </div>
            <div class="form-group">
                <label>Tolerance (mm) *</label>
                <input class="input" type="number" step="0.01" @bind="_toleranceMm" />
                <small>이 값을 초과하는 편차는 불량으로 판정합니다.</small>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert--error">@_errorMessage</div>
        }

        <label for="fileInput" style="
            display:block;
            border: 2px dashed #334155;
            border-radius: 14px;
            padding: 36px;
            text-align: center;
            cursor: pointer;
            margin-bottom: 20px;
        ">
            <div style="font-size:2rem; margin-bottom:8px;">📂</div>
            @if (_file is null)
            {
                <p style="color:#94a3b8;">클릭해서 <strong>.csv</strong> 또는 <strong>.ply</strong> 파일 선택</p>
            }
            else
            {
                <p style="color:#22c55e; font-weight:600;">✓ @_file.Name</p>
            }
        </label>

        <div class="form-actions">
            <a href="/" class="btn btn-outline">Cancel</a>
            <button class="btn btn-primary" disabled="@_submitting" @onclick="Submit">
                @(_submitting ? "검사 중…" : "Run Inspection")
            </button>
        </div>
    }

    @if (_step == Step.Running)
    {
        <div class="progress-state">
            <div class="spinner spinner--large"></div>
            <h2>점군 분석 중…</h2>
            <p>최적평면을 피팅하고 편차를 계산합니다.</p>
        </div>
    }

    @if (_step == Step.Done && _result is not null)
    {
        <div class="result-card @(_result.Passed ? "result-card--pass" : "result-card--fail")">
            <div class="result-header">
                <span class="result-icon">@(_result.Passed ? "✅" : "❌")</span>
                <h2>@(_result.Passed ? "PASS" : "FAIL")</h2>
            </div>
            <div class="result-grid">
                <div class="result-item">
                    <span class="result-label">Flatness Error</span>
                    <span class="result-value">@_result.FlatnessErrorMm.ToString("F4") mm</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Tolerance</span>
                    <span class="result-value">±@_result.ToleranceMm.ToString("F2") mm</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Points Inspected</span>
                    <span class="result-value">@_result.TotalPoints.ToString("N0")</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Out of Tolerance</span>
                    <span class="result-value">@_result.OutOfToleranceCount</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Min Deviation</span>
                    <span class="result-value">@_result.MinDeviationMm.ToString("F4") mm</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Max Deviation</span>
                    <span class="result-value">@_result.MaxDeviationMm.ToString("F4") mm</span>
                </div>
                <div class="result-item">
                    <span class="result-label">RMS Deviation</span>
                    <span class="result-value">@_result.RmsDeviationMm.ToString("F4") mm</span>
                </div>
            </div>
            <div class="form-actions">
                <button class="btn btn-outline" @onclick="Reset">New Inspection</button>
                <button class="btn btn-primary" @onclick="GoToDetail">View Full Report</button>
            </div>
        </div>
    }

    <div style="display:none;">
        <InputFile id="fileInput" OnChange="HandleFileSelected" accept=".csv,.ply" />
    </div>

</div> 



@code {
    private enum Step { Form, Running, Done }

    private Step _step = Step.Form;
    private string _partName = string.Empty;
    private string _partNumber = string.Empty;
    private double _toleranceMm = 0.5;
    private IBrowserFile? _file;
    private bool _submitting = false;
    private string? _errorMessage;
    private InspectionResultDto? _result;
    private int _sessionId;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _file = e.File;
        _errorMessage = null;
    }

    private async Task Submit()
    {
        _errorMessage = null;

        if (_file is null)
        {
            _errorMessage = "파일을 선택해주세요.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_partName) || string.IsNullOrWhiteSpace(_partNumber))
        {
            _errorMessage = "Part Name과 Part Number를 입력해주세요.";
            return;
        }

        _submitting = true;
        _step = Step.Running;
        StateHasChanged();

        try
        {
            // 1. 세션 생성
            var createResp = await Http.PostAsJsonAsync("api/inspections", new
            {
                PartName = _partName,
                PartNumber = _partNumber,
                ToleranceMm = _toleranceMm
            });

            if (!createResp.IsSuccessStatusCode)
            {
                _errorMessage = "세션 생성 실패.";
                _step = Step.Form;
                return;
            }

            var session = await createResp.Content.ReadFromJsonAsync<SessionIdDto>();
            _sessionId = session!.Id;

            // 2. 파일 업로드
            using var content = new MultipartFormDataContent();
            var stream = _file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new("application/octet-stream");
            content.Add(streamContent, "file", _file.Name);

            var uploadResp = await Http.PostAsync($"api/inspections/{_sessionId}/upload", content);

            if (!uploadResp.IsSuccessStatusCode)
            {
                var err = await uploadResp.Content.ReadAsStringAsync();
                _errorMessage = $"검사 실패: {err}";
                _step = Step.Form;
                return;
            }

            _result = await uploadResp.Content.ReadFromJsonAsync<InspectionResultDto>();
            _step = Step.Done;
        }
        catch (Exception ex)
        {
            _errorMessage = $"오류: {ex.Message}";
            _step = Step.Form;
        }
        finally
        {
            _submitting = false;
        }
    }

    private void Reset()
    {
        _step = Step.Form;
        _file = null;
        _result = null;
        _errorMessage = null;
    }

    private void GoToDetail() => Nav.NavigateTo($"/inspection/{_sessionId}");

    private record SessionIdDto(int Id);

    private record InspectionResultDto(
        bool Passed, int TotalPoints,
        double FlatnessErrorMm, double MinDeviationMm, double MaxDeviationMm,
        double RmsDeviationMm, int OutOfToleranceCount, double ToleranceMm);
}
